{
  "expo": {
    "name": "F5 Chat",
    "slug": "chat-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "chatapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Cho phép F5 Chat truy cập camera để thực hiện cuộc gọi video và gửi hình ảnh.",
        "NSMicrophoneUsageDescription": "Cho phép F5 Chat truy cập micro để thực hiện cuộc gọi thoại và video.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.chatapp"
    },
    "android": {
      "package": "com.chatapp",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-audio",
      "expo-video",
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-localization",
      [
        "expo-camera",
        {
          "cameraPermission": "Cho phép F5 Chat truy cập camera để thực hiện cuộc gọi video và chụp ảnh.",
          "microphonePermission": "Cho phép F5 Chat truy cập micro để thực hiện cuộc gọi thoại và video.",
          "recordAudioAndroid": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8be3f988-3209-4b85-a92f-3ec9bc619268"
      }
    }
  }
}
